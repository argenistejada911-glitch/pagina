<script src="https://cdn.tailwindcss.com"></script>

<div class="max-w-md mx-auto mt-10 bg-white shadow-lg rounded-lg overflow-hidden">
    
    <div class="text-2xl py-4 px-6 bg-gray-900 text-white text-center font-bold uppercase">
        Coloque su información
    </div>

    <form class="py-4 px-6" action="" method="POST">

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Name</label>
            <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"
            type="text" placeholder="Enter your name">
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Email</label>
            <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"
            type="email" placeholder="Enter your email">
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Phone Number</label>
            <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"
            type="tel" placeholder="Enter your phone number">
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Date</label>
            <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"
            type="date">
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Time</label>
            <input class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"
            type="time">
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Service</label>
            <select class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700">
                <option>Select a service</option>
                <option>Haircut</option>
                <option>Coloring</option>
                <option>Styling</option>
                <option>Facial</option>
            </select>
        </div>

        <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Message</label>
            <textarea class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700"
            rows="4" placeholder="Enter any additional information"></textarea>
        </div>

        <div class="flex items-center justify-center mb-4">
            <button class="bg-gray-900 text-white py-2 px-4 rounded hover:bg-gray-800"
            type="submit">
                Enviar
            </button>
        </div>

        <div class="text-center">
            <a href="inicio.html"
            style="background:#0b1c35; color:white; padding:10px 20px; text-decoration:none; border-radius:6px;">
            inicio
            </a>
        </div>

    </form>
</div>
